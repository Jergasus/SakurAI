# ============================================
# SakurAI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Only GEMINI_API_KEY is required. Everything else has sensible defaults.

# REQUIRED: Your Google Gemini API Key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection (default uses the local Docker container)
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/saas_agents
# MONGO_URI=mongodb://mongo:27017/saas_agents

# JWT Secret for authentication tokens (change in production!)
# JWT_SECRET=your-secret-key-here

# Vector Search Mode: "local" (default, in-memory cosine) or "atlas" (requires Atlas vector_index)
# VECTOR_SEARCH_MODE=local

# CORS: Allow all origins (recommended and safe for widget embedding).
# The API key is the security boundary, not CORS — same as Intercom, Crisp, etc.
# CORS_ALLOW_ALL=true

# Or specify allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# Default admin credentials (only used on first run when no users exist)
# DEFAULT_ADMIN_EMAIL=admin@sakurai.com
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_ADMIN_NAME=My Agent

# Frontend URL (used for CORS when CORS_ALLOW_ALL is false)
# FRONTEND_URL=http://localhost

# Rate limiting (requests per time window per IP)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=60

# Port mapping (change to run multiple instances on the same server)
# WEB_PORT=80
